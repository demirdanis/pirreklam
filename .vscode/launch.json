{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js SSR (pnpm dev:web)",
      "type": "node",
      "request": "launch",

      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:web"],

      "cwd": "${workspaceFolder}",

      "env": {
        "NODE_OPTIONS": "--inspect"
      },

      "console": "integratedTerminal",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
